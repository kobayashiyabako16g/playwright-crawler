{
  "$schema": "https://turborepo.org/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "dev": {
    },
    "cleanup": {
      "cache": false
    },
    "quality": {
      "dependsOn": ["lint", "format"]
    },
    "quality:fix": {
      "dependsOn": ["lint:fix", "format:fix"]
    },
    "lint": {},
    "lint:fix": {
      "cache": false
    },
    "format": {},
    "format:fix": {
      "cache": false
    },
    "test": {
      "cache": true
    }
  }
}

