{
  "$schema": "https://turborepo.org/schema.json",
  "globalPassThroughEnv": [
    "GOOGLE_CLOUD_PROJECT",
    "GOOGLE_CLOUD_LOCATION",
    "GOOGLE_GENAI_USE_VERTEXAI",
    "GENERATIVE_MODEL_NAME"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "quality": {
      "dependsOn": ["lint", "format:check"]
    },
    "quality:fix": {
      "dependsOn": ["lint:fix", "format"]
    },
    "lint": {
      "cache": true
    },
    "lint:fix": {
      "cache": false
    },
    "format": {
      "cache": false
    },
    "format:check": {
      "cache": true
    },
    "test": {
      "cache": true
    }
  }
}